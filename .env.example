# =============================================================================
# SwarAI — copy to `.env` and fill before first run (see README Quick start).
#
# Minimum to try the dashboard + simulator (after Supabase migrations):
#   CLERK_*, NEXT_PUBLIC_SUPABASE_*, SUPABASE_SERVICE_ROLE_KEY, LIVEKIT_*,
#   SARVAM_API_KEY, SWARAI_INTERNAL_WEBHOOK_SECRET, SWARAI_APP_URL, NEXT_PUBLIC_APP_URL
#
# Payments (pick one or more; Settings shows “Payment readiness”):
#   Stripe: STRIPE_SECRET_KEY + STRIPE_PRO_PRICE_ID + STRIPE_WEBHOOK_SECRET (webhook URL in Settings)
#   Razorpay: RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET + RAZORPAY_WEBHOOK_SECRET
#   PayU: PAYU_MERCHANT_KEY + PAYU_MERCHANT_SALT + PAYU_MODE + NEXT_PUBLIC_APP_URL
#
# Legal / ops: customize Dashboard → Legal drafts; run supabase/verify_schema.sql after migrations.
# =============================================================================

# --- Clerk (dashboard auth) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- App URL (webhooks, redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (prefer Mumbai / India region) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LiveKit ---
LIVEKIT_URL=https://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Internal: worker → web transcript callback ---
SWARAI_INTERNAL_WEBHOOK_SECRET=change-me-long-random
# Worker uses this to reach the Next app (use http://web:3000 in Docker Compose)
SWARAI_APP_URL=http://localhost:3000

# --- Sarvam (voice worker) ---
SARVAM_API_KEY=
SARVAM_DEFAULT_SPEAKER=anushka

# --- Telephony (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
LIVEKIT_SIP_URI=
LIVEKIT_SIP_USERNAME=
LIVEKIT_SIP_PASSWORD=
# Map each call to its LiveKit room (recommended for inbound + concurrent outbound):
# LIVEKIT_SIP_ROOM_HOST=sip.your-livekit-sip.example.com
# Or: LIVEKIT_SIP_DIAL_URI_TEMPLATE=sip:{room}@sip.yourdomain.com
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_TOKEN=
EXOTEL_CALLER_ID=

# --- Billing (optional) ---
# PayU India (hosted checkout — key/salt from PayU dashboard)
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
# test | production (selects PayU host)
PAYU_MODE=test
SWARAI_PAYU_DEMO_AMOUNT_INR=100
SWARAI_PAYU_PRO_AMOUNT_INR=999

STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
# Stripe Dashboard → Webhooks → signing secret (checkout.session.completed, customer.subscription.deleted)
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook signature verification (dashboard webhook secret)
RAZORPAY_WEBHOOK_SECRET=
# Optional: default Pro checkout amount (paise) for dashboard “Pro order” button
SWARAI_RAZORPAY_PRO_AMOUNT_PAISE=99900
# Optional: auto-upgrade to Pro on payment.captured when amount >= this (still needs swarai_org_id in notes)
SWARAI_RAZORPAY_PRO_MIN_PAISE=

# --- AI helpers (optional) ---
OPENAI_API_KEY=
# Worker: OpenAI LLM model when stack is openai or deepgram_elevenlabs_openai
SWARAI_OPENAI_LLM_MODEL=gpt-4.1-mini
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Outbound webhooks (optional; org can override in dashboard) ---
SWARAI_WEBHOOK_SIGNING_SECRET=
# Fallback HMAC secret for the optional second CRM POST (org settings.crmWebhookSecret wins)
SWARAI_CRM_WEBHOOK_SECRET=

# --- WhatsApp (optional, Meta Cloud API) ---
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: Meta “Linked agent” id for some flows
WHATSAPP_LINKED_AGENT_ID=

# --- Google Calendar (service account; dashboard also has authenticated route) ---
# JSON string of the service account key (single line or escaped newlines in private_key)
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# --- Pinecone RAG (optional; namespace = agent id; else pgvector path) ---
PINECONE_HOST=
PINECONE_API_KEY=

# --- Redis (rate limits / future queues) ---
REDIS_URL=redis://localhost:6379

# --- Freemium (org settings.plan === "free" uses this daily cap unless maxVoiceSessionsPerDay is set) ---
SWARAI_DEFAULT_FREE_VOICE_SESSIONS_PER_DAY=30

# --- Optional: OpenAI sentiment on call end (in addition to heuristic) ---
# SWARAI_SENTIMENT_MODEL=gpt-4o-mini
